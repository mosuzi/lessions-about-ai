{
  "name": "ai-modern-guide-blog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.3",
  "description": "A Docusaurus knowledge site for learning how to use modern AI tools well.",
  "scripts": {
    "start": "docusaurus start --host 127.0.0.1 --port 5454",
    "build": "docusaurus build",
    "serve": "docusaurus serve --host 127.0.0.1 --port 5454",
    "serve:static": "python3 -m http.server 5454 --bind 127.0.0.1 --directory build"
  },
  "dependencies": {
    "@docusaurus/core": "latest",
    "@docusaurus/preset-classic": "latest",
    "@mdx-js/react": "latest",
    "clsx": "latest",
    "prism-react-renderer": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "latest",
    "@docusaurus/plugin-content-docs": "3.10.1",
    "@docusaurus/types": "3.10.1"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  }
}
